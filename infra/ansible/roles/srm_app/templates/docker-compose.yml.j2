name: srm-oriental-gateway

services:
  # ----------------------------------------------------------------------------
  # PRIMARY DATABASE (PostgreSQL)
  # ----------------------------------------------------------------------------
  srm-db:
    image: postgres:16-alpine
    container_name: srm-db
    environment:
      - POSTGRES_USER={{ postgres_user }}
      - POSTGRES_PASSWORD={{ postgres_password }}
      - POSTGRES_DB={{ postgres_db }}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - back-net
    restart: always

  # ----------------------------------------------------------------------------
  # BACKEND API (.NET)
  # ----------------------------------------------------------------------------
  srm-api:
    image: {{ dockerhub_user }}/srm-api:{{ image_tag }}
    container_name: srm-api
    environment:
      # Injecting the DB connection directly via environment variable
      - "ConnectionStrings__DefaultConnection=Host=srm-db;Port={{ db_internal_port }};Database={{ postgres_db }};Username={{ postgres_user }};Password={{ postgres_password }}"
    volumes:
      - ocr_shared_volume:/app/uploads
    networks:
      - web-net
      - back-net
    restart: always
    depends_on:
      - srm-db

  # ----------------------------------------------------------------------------
  # WORKER OCR (Python + Tesseract)
  # ----------------------------------------------------------------------------
  srm-ocr-worker:
    image: {{ dockerhub_user }}/srm-ocr-worker:{{ image_tag }}
    container_name: srm-ocr-worker
    environment:
      - STORAGE_PENDING_PATH=/home/srm_worker/app/uploads/pending
      - STORAGE_PROCESSED_PATH=/home/srm_worker/app/uploads/processed
      - STORAGE_FAILED_PATH=/home/srm_worker/app/uploads/failed
    volumes:
      # Mounting the exact same named volume so they share files perfectly
      - ocr_shared_volume:/home/srm_worker/app/uploads      
    networks:
      - back-net
    restart: on-failure

  # ----------------------------------------------------------------------------
  # FRONTEND DASHBOARD (React + Nginx Proxy)
  # ----------------------------------------------------------------------------
  srm-dashboard:
    image: {{ dockerhub_user }}/srm-dashboard:{{ image_tag }}
    container_name: srm-dashboard
    ports:
      - "{{ dashboard_external_port }}:{{ dashboard_internal_port }}"
    volumes:
      - ./nginx/public.conf:/etc/nginx/conf.d/default.conf:ro
      - ./nginx/security_headers.conf:/etc/nginx/conf.d/security_headers.conf:ro
    networks:
      - web-net
    restart: always
    depends_on:
      - srm-api

networks:
  web-net:
  back-net:

volumes:
  postgres_data:
  ocr_shared_volume: # The new named volume that replaces the local bind mount