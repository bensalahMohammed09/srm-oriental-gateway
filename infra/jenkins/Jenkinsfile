pipeline {
    agent any

   

    environment {
        SONAR_SCANNER_TOOL = 'sonar-scanner'
        SONAR_SERVER_NAME = 'sonarqube'
    }

    stages{

        stage('0. Préparation de l\'environnement'){
                steps{
                    script{
                        cleanWs() // Nettoie l'espace de travail pour éviter les conflits avec d'anciennes données  
                        echo 'Récupération du fichier .env depuis le volume partagé...'
                        sh "cp /tmp/.env.srm .env"
                        echo 'Fichier .env copié avec succès !'
                }
            }
        }
        stage('1. Récupération du Code'){
            steps{
                echo 'Récupération des sources depuis GitHub...'
                checkout scm
            }
            
        }

        stage('2. Analyse de Qualité (SonnarQube)'){
           steps {
             script{
                echo 'Audit du code source encours...'
                def scannerHome = tool name:"${env.SONAR_SCANNER_TOOL}"
                withSonarQubeEnv("${env.SONAR_SERVER_NAME}"){
                        // We execute the scan for the entire from the root
                        sh "${scannerHome}/bin/sonar-scanner -Dsonar.projectKey=srm-oriental-gateway -Dsonar.sources=. -Dsonar.host.url=http://sonarqube:9002"
                    }
             }
           }
        }

        stage('----- Quality Gate -----'){
            steps{
               script{
                    echo " Attente du verdict de qualité de SonarQube..."
                    timeout(time: 5, unit: 'MINUTES') {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Échec du Quality Gate : ${qg.status}"
                        } else {
                            echo "Quality Gate réussi : ${qg.status}"
                        }
                    }
               }
            }
        }

        stage('3. Construction of the infrastructure'){
            steps{
                echo "Build docker images ...."
                sh "docker compose --env-file .env build"
            }
        }

        stage('4. Déploiment des services'){
            steps{
                echo 'Lancement des conteneurs...'
                sh "docker compose --env-file .env up -d"
            }
        }

        stage('5. Vérification finale'){
            steps{
                echo "---- Etat des conteneurs : ----"
                sh "docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'"
            }
        }
    }

    post{
        success{
            echo "Pipeline exécuté avec succès !"
        }
        failure{
            echo "Pipeline échoué. Veuillez vérifier les logs pour plus de détails."
        }
        always{
            echo "Fin de l'exécution du pipeline."
            echo "Nettoyage des ressources temporaires..."
            sh "docker image prune -f"
        }
    }
}