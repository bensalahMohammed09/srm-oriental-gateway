pipeline{
    agent any

    // Global flags for the pipeline orchestration
    environment{
        BUILD_BACKEND = "false"
        BUILD_FRONTEND = "false"
        BUILD_WORKERS = "false"
        FORCE_ALL = "false"
    }

    stages{
        stage('Step 1.1: Path Detection & Workspace Preparation'){
            steps{
                script{
                    // 1. Manual Cleanup
                    // Ensures a stateless environment by removing all files 
                    echo "Cleaning workspace..."
                    sh "rm -rf *"

                    // 2. Fresh Checkout
                    checkout scm

                    // 3. Change Detection Logic
                    // Compare the current commit against the last successfull one 
                    def lastSuccess = env.GIT_PREVIOUS_SUCCESSFUL_COMMIT ?: "HEAD~1"
                    def changedFiles = sh(script: "git diff --name-only ${lastSuccess} ${env.GIT_COMMIT}",returnStdout: true)

                    echo "Checking changes between ${lastSuccess} and current commit..."
                    for (file in changedFiles){
                        echo "Detected change in: ${file}"

                        // Global Trigger: Changes in core infra or jenkins config force a full system rebuild
                        if(file.startsWith('infra/') || file.endsWith('Jenkinsfile') || file.endsWith('docker-compose.yml')){
                            echo "CRITICAL: Global configuration change detected (${file}) forcing Full Rebuild."
                            BUILD_BACKEND = "true"
                            BUILD_FRONTEND = "true"
                            BUILD_WORKERS = "true"
                            FORCE_ALL = "true"
                            break
                        }

                        //Component-specific check
                        if(file.startsWith('src/backend/')){
                            env.BUILD_BACKEND = "true"
                        }
                        if(file.startsWith('src/frontend/')){
                            env.BUILD_FRONTEND = "true"
                        }
                        if(file.startsWith('src/workers/')){
                            env.BUILD_WORKERS = "true"
                        }
                    }
                }
            }
        }

        stage('Step 1.1: Verification'){
            steps{
                echo "--- Final Build Decisions ---"
                echo "Run Backend Pipeline: ${env.BUILD_BACKEND}"
                echo "Run Frontend Pipeline: ${env.BUILD_FRONTEND}"
                echo "Run Workers Pipeline: ${env.BUILD_WORKERS}"
                echo "Force Full Rebuild: ${env.FORCE_ALL}"
            }
        }
    }
}