def getServiceMap() {
    return [
        'infra/docker/api.Dockerfile' : 'srm-api',
        'infra/docker/db.Dockerfile' : 'srm-db',
        'infra/docker/dashboard.Dockerfile' : 'srm-dashboard',
        'infra/docker/worker.Dockerfile' : 'srm-ocr-worker',
        'infra/docker/promtail.Dockerfile' : 'promtail',
        'infra/docker/node-exporter.Dockerfile' : 'node-exporter',
        'infra/docker/sonar-db.Dockerfile' : 'sonar-db',
        'infra/docker/sonarqube.Dockerfile' : 'sonarqube',
        'infra/docker/grafana.Dockerfile' : 'grafana',
        'infra/docker/jenkins.Dockerfile' : 'jenkins-srm'
    ]
}

def changedFiles = []
pipeline {
    agent any

    environment {
       RUN_SONAR_BACKEND = "false"
       RUN_SCAN_FRONTEND = "false"
       RUN_SCAN_WORKER = "false"
       FORCE_ALL = "false"
       RUN_TRIVY = "false"
       GIT_SHA = ""
    }

    stages {
        stage('0. Preparation') {
            steps {
                script {
                    echo "Cleaning workspace and fixing Git permissions..."
                    deleteDir()
                    sh "git config --global --add safe.directory '*'"
                    checkout scm

                    // Secure Secret Injection using Jenkins Credentials plugin
                    // Ensure you have a 'Secret file' credential named 'srm-env-file' in Jenkins
                    withCredentials([file(credentialsId: 'srm-env-file', variable: 'SECRET_ENV')]) {
                        sh "cp \$SECRET_ENV ./.env"
                        echo "SUCCESS: .env file injected into workspace."
                    }
                    env.GIT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    echo "Current Git SHA: ${env.GIT_SHA}"
                }
            }
        }

      stage('1. Intelligent Path Detection') {
    steps {
        script {
            // 1. Détection du diff (Texte brut)
            def rawDiff = sh(
                script: "git diff-tree --no-commit-id --name-only -r HEAD", 
                returnStdout: true
            ).trim()

            echo "Fichiers bruts :\n${rawDiff}"

            // 2. L'astuce ultime : on encadre le texte de sauts de ligne.
            // Cela permet de chercher des chemins exacts sans utiliser de listes ou Regex.
            def safeDiff = "\n" + rawDiff + "\n"

            // 3. Évaluation via recherche de texte simple (Impossible à faire planter par Jenkins)
            boolean forceAll  = safeDiff.contains('\ndocker-compose.yml\n') || safeDiff.contains('\n.env.example\n')
            boolean runSonar  = safeDiff.contains('\nsrc/backend/')
            boolean runNpm    = safeDiff.contains('\nsrc/frontend/')
            boolean runBandit = safeDiff.contains('\nsrc/workers/')

            // 5. La règle Trivy
            // Si n'importe quel scan s'active, l'image change, donc on lance Trivy.
            boolean runTrivy = (forceAll || runSonar || runNpm || runBandit)

            // 6. Injection dans l'environnement Jenkins
            env.FORCE_ALL         = forceAll.toString()
            env.RUN_SONAR_BACKEND = runSonar.toString()
            env.RUN_SCAN_FRONTEND = runNpm.toString()
            env.RUN_SCAN_WORKER   = runBandit.toString()
            env.RUN_TRIVY         = runTrivy.toString()

            echo """
            =========================
            --- ÉTAT DES SCANS ---
            FORCE_ALL : ${env.FORCE_ALL}
            BACKEND   : ${env.RUN_SONAR_BACKEND}
            FRONTEND  : ${env.RUN_SCAN_FRONTEND}
            WORKER    : ${env.RUN_SCAN_WORKER}
            TRIVY     : ${env.RUN_TRIVY}
            =========================
            """
        }
    }
}
        stage('3. Backend Analysis with SonarQube') {
            when { 
                expression { env.RUN_SONAR_BACKEND == "true" } 
            }
            steps {
                script {
                    try {
                        sh "docker start sonar-db sonarqube"
                        sh 'timeout 120s bash -c "until curl -s http://sonarqube:9002/api/system/status | grep -q UP; do sleep 5; done"'

                        echo "Running SonarQube analysis for Backend..."
                        withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                            withSonarQubeEnv('sonarqube') {
                                sh """
                                    dotnet sonarscanner begin /k:"srm-backend" \
                                    /d:sonar.login="${SONAR_TOKEN}" \
                                    /d:sonar.host.url=http://sonarqube:9002

                                    dotnet build src/backend/Srm.Gateway.sln --configuration Release
                                    dotnet sonarscanner end /d:sonar.login="${SONAR_TOKEN}"
                                """
                            }
                        }

                        timeout(time: 5, unit: 'MINUTES') {
                            def qg = waitForQualityGate()
                            if (qg.status != 'OK') {
                                error "SonarQube Quality Gate failed: ${qg.status}"
                            }
                        }
                    } finally {
                        // Ensures services are stopped even if the analysis or build fails
                        sh "docker stop sonar-db sonarqube || true"
                    }
                }
            }
        }

        stage('4. Frontend & Worker Scan') {
            parallel {
                stage('Frontend - NPM Audit') {
                    when {
                        expression { env.RUN_SCAN_FRONTEND == "true"}
                    }
                    steps {
                        dir('src/frontend') {
                            echo "Running NPM Audit for Frontend..."
                            sh "npm audit --audit-level=high"
                        }
                    }
                }
                stage('Worker - Bandit Scan') {
                    when {
                        expression { env.RUN_SCAN_WORKER == "true"}
                    }
                    steps {
                        dir('src/workers/ocr-service') {
                            echo "Running Bandit Scan for Worker..."
                            sh "bandit -r . -ll -ii"
                        }
                    }
                }
            }
        }

        stage('5. Mandatory Full Scan') {
            when {
                expression { env.RUN_TRIVY == "true" }
            }
            steps {
                echo "Running full scans for all components due to critical changes..."
                sh "trivy fs --severity HIGH,CRITICAL --exit-code 1 ."
            }
        }

        stage('6. Custom Containers build') {
            steps {
               script {
                    def services = getServiceMap()
                    services.each { infraPath, imageName ->
                    if (imageName == 'jenkins-srm') return 

                    // 1. Base : on build si le Dockerfile a changé ou si on force tout
                    def shouldBuild = (changedFiles.any { it == infraPath } || env.FORCE_ALL == "true")

                    // 2. On lie le code source aux images spécifiques
                    if (imageName == 'srm-api' && env.RUN_SONAR_BACKEND == "true") { shouldBuild = true }
                    if (imageName == 'srm-dashboard' && env.RUN_SCAN_FRONTEND == "true") { shouldBuild = true }
                    if (imageName == 'srm-ocr-worker' && env.RUN_SCAN_WORKER == "true") { shouldBuild = true }
 
                    // 3. Exécution du build si une des conditions est vraie
                    if (shouldBuild) {
                        echo "BUILDING: ${imageName} (SHA: ${env.GIT_SHA})"
                        sh "docker build -t ${imageName}:${env.GIT_SHA} -f ${infraPath} ."
                    } else {
                        echo "SKIP: No changes for ${imageName}"
                    } 
                } 
            }
        }
    }

        stage('7. Orchestrated Compose') {
            steps {
                script {
                   echo "Injection des configurations par flux (Direct Pipe)..."
                    def projectPrefix = "srm-oriental-gateway"
                    
                    // 1. On s'assure que les volumes sont propres
                    sh "docker volume rm ${projectPrefix}_loki_config || true"
                    sh "docker volume rm ${projectPrefix}_prometheus_config || true"
                    sh "docker volume rm ${projectPrefix}_promtail_config || true"
                    
                    sh "docker volume create ${projectPrefix}_loki_config"
                    sh "docker volume create ${projectPrefix}_prometheus_config"
                    sh "docker volume create ${projectPrefix}_promtail_config"
                    
                    // 2. On utilise 'cat' pour lire le fichier et on le redirige dans le volume
                    // Cette méthode ne dépend PAS des chemins de l'hôte (Windows)
                    sh "cat infra/loki/loki-config.yml | docker run --rm -i -v ${projectPrefix}_loki_config:/dest alpine sh -c 'cat > /dest/local-config.yaml'"
                    sh "cat infra/prometheus/prometheus.yml | docker run --rm -i -v ${projectPrefix}_prometheus_config:/dest alpine sh -c 'cat > /dest/prometheus.yml'"
                    sh "cat infra/promtail/promtail-config.yml | docker run --rm -i -v ${projectPrefix}_promtail_config:/dest alpine sh -c 'cat > /dest/config.yml'"

                    echo "Démarrage de la stack..."
                      sh """
                            docker compose up -d \
                            --force-recreate \
                            --always-recreate-deps \
                            --remove-orphans \
                            \$(docker compose config --services | grep -vE 'jenkins-srm|sonarqube|sonar-db')
                        """
                    echo "Cleaning up...."
                    sh "docker system prune -f"
                }
            }
        }
    }

    post{
        always{
            deleteDir()
        }
        success{
            echo "SUCCESS: Pipeline finished."
        }
        failure{
            echo "FAILED: Pipeline failed. Check the logs!"
        }
    }
}