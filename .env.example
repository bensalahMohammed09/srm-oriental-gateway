# =================================================================
# SRM ORIENTAL GATEWAY - Environment Template
# Instructions: Copy this file to '.env' and fill in the values.
# =================================================================

# --- GLOBAL CONFIG ---
PROJECT_NAME=srm-oriental-gateway
NODE_ENV=development
SRM_USER_ID=1001
SRM_GROUP_ID=1001

# --- VERSIONS ---
DOTNET_VERSION=9.0-alpine
NODE_VERSION=20-alpine
NGINX_VERSION=stable-alpine
PYTHON_VERSION=3.11-slim
POSTGRES_VERSION=15-alpine
N8N_VERSION=latest
PROMETHEUS_VERSION=v2.45.0
LOKI_VERSION=2.9.1
PROMTAIL_VERSION=2.9.1
GRAFANA_VERSION=10.2.3
NODE_EXPORTER_VERSION=v1.7.0
SONAR_VERSION=community

# --- PORTS & CREDENTIALS ---

# Service 1: srm-api
API_INTERNAL_PORT=9000
API_EXTERNAL_PORT=5050
API_ENV=development

# Service 2: srm-dashboard
DASHBOARD_INTERNAL_PORT=8080
DASHBOARD_EXTERNAL_PORT=3000

# Service 3: srm-db
POSTGRES_DB=srm_gateway_db
POSTGRES_USER=srm_admin
POSTGRES_PASSWORD=your_secure_password_here
DB_INTERNAL_PORT=5433
DB_EXTERNAL_PORT=6000

# Service 4: n8n
N8N_ENCRYPTION_KEY=your_encryption_key_here
N8N_INTERNAL_PORT=5679
N8N_EXTERNAL_PORT=7000

# Service 5: Monitoring & Logging
PROMETHEUS_INTERNAL_PORT=9091
PROMETHEUS_EXTERNAL_PORT=9091

LOKI_INTERNAL_PORT=3101
LOKI_EXTERNAL_PORT=3101

PROMTAIL_INTERNAL_PORT=9081

GRAFANA_INTERNAL_PORT=3001
GRAFANA_EXTERNAL_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_password_here

NODE_EXPORTER_INTERNAL_PORT=9101
NODE_EXPORTER_EXTERNAL_PORT=9101

# Service 6: SonarQube & Sonar-DB
SONAR_INTERNAL_PORT=9000
SONAR_EXTERNAL_PORT=9002

SONAR_DB_NAME=sonar_db
SONAR_DB_USER=sonar_admin
SONAR_DB_PASSWORD=sonar_db_password_here
SONAR_DB_INTERNAL_PORT=5432
SONAR_DB_EXTERNAL_PORT=5435

# Database Link (Logical bridge for SonarQube)
SONAR_JDBC_USERNAME=sonar_admin
SONAR_JDBC_PASSWORD=sonar_db_password_here
SONAR_JDBC_URL=jdbc:postgresql://sonar-db:5432/sonar_db